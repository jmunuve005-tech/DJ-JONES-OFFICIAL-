<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DJ Jones Official | Bookings</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Poppins',sans-serif; background:#050505; color:white; }

    header {
      position:fixed; width:100%; top:0;
      display:flex; justify-content:space-between; align-items:center;
      padding:15px 30px; background:rgba(0,0,0,0.8);
      backdrop-filter:blur(10px); z-index:1000;
    }

    nav a { margin-left:20px; color:white; text-decoration:none; }
    nav a:hover { color:#ff0055; }

    .hero {
      height:100vh;
      background:url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30') center/cover;
      display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center;
    }

    .hero h1 { font-size:60px; }
    .hero p { opacity:0.8; margin-top:10px; }

    .btn {
      margin-top:20px; padding:14px 35px; border:none;
      background:#ff0055; color:white; cursor:pointer;
      font-weight:bold; border-radius:30px;
    }

    section { padding:80px 20px; text-align:center; }

    .grid {
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px; margin-top:30px;
    }

    .card {
      background:#111; padding:25px; border-radius:15px;
      transition:0.3s;
    }

    .card:hover {
      transform:translateY(-10px);
      box-shadow:0 10px 30px rgba(255,0,85,0.4);
    }

    .price {
      font-size:28px; color:#ff0055; margin:15px 0;
    }

    form {
      max-width:400px; margin:30px auto;
      display:flex; flex-direction:column; gap:15px;
    }

    input, textarea {
      padding:12px; border:none; border-radius:8px;
      background:#111; color:white;
    }

    footer { text-align:center; padding:20px; background:black; }
  </style>
</head>
<body>

<header>
  <h2>DJ JONES OFFICIAL</h2>
  <nav>
    <a href="#home">Home</a>
    <a href="#packages">Packages</a>
    <a href="#music">Music</a>
    <a href="#booking">Book</a>
  </nav>
</header>

<section class="hero" id="home">
  <h1>BOOK THE VIBE</h1>
  <p>Premium DJ Experience for Clubs, Weddings & Events</p>
  <button class="btn" onclick="document.getElementById('packages').scrollIntoView({behavior:'smooth'})">VIEW PACKAGES</button>
</section>

<section id="packages">
  <h2>Booking Packages</h2>
  <div class="grid">
    <div class="card">
      <h3>Starter</h3>
      <div class="price">KES 10,000</div>
      <p>• 2 Hour Set</p>
      <p>• Basic Setup</p>
      <button class="btn" onclick="scrollToBooking()">Book Now</button>
    </div>
    <div class="card">
      <h3>Club Experience</h3>
      <div class="price">KES 25,000</div>
      <p>• 4 Hour Set</p>
      <p>• Hype + MC Energy</p>
      <p>• Crowd Control</p>
      <button class="btn" onclick="scrollToBooking()">Book Now</button>
    </div>
    <div class="card">
      <h3>Premium Event</h3>
      <div class="price">KES 50,000+</div>
      <p>• Full Night Performance</p>
      <p>• Custom Playlist</p>
      <p>• Branding + Drops</p>
      <button class="btn" onclick="scrollToBooking()">Book Now</button>
    </div>
  </div>
</section>

<section id="music">
  <h2>Listen to My Mixes</h2>
  <div class="grid">
    <iframe width="100%" height="200" src="https://www.youtube.com/embed/dQw4w9WgXcQ"></iframe>
    <iframe width="100%" height="200" src="https://www.youtube.com/embed/dQw4w9WgXcQ"></iframe>
  </div>
</section>

<section id="booking">
  <h2>Secure Your Date</h2>
  <form onsubmit="sendBooking(event)">
    <input type="text" placeholder="Your Name" required>
    <input type="email" placeholder="Your Email" required>
    <input type="text" placeholder="Event Type" required>
    <input type="date" required>
    <textarea placeholder="Event Details"></textarea>
    <button class="btn">Send Booking</button>
  </form>
  <p>Or WhatsApp: <b>0720678941</b></p>
</section>

<footer>
  © 2026 DJ Jones Official | BOOKINGS OPEN
</footer>

<script>
function scrollToBooking(){
  document.getElementById('booking').scrollIntoView({behavior:'smooth'});
}

function sendBooking(e){
  e.preventDefault();
  alert('Booking request received! We will contact you shortly.');
}
</script>

</body>
</html>
